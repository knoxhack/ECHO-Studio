{
  "name": "echo-studio",
  "productName": "ECHO Studio",
  "version": "0.1.0",
  "description": "Design ECHO experiences, wire modules, run local dev tools, validate projects, and package releases.",
  "author": "ECHO Platform",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "doctor:electron": "node scripts/doctor-electron.mjs",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,mjs,json,css}\"",
    "dist": "electron-vite build && electron-builder",
    "dist:publish": "npm run dist -- --publish always",
    "dist:publish:public": "npm run dist:publish"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "electron-updater": "^6.3.0",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "eslint": "^9.14.0",
    "eslint-plugin-react": "^7.37.2",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.14.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  }
}
