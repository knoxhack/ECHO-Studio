{
  "name": "echo-addon-studio",
  "version": "0.1.0",
  "description": "Build addons, expansions, and custom content for the ECHO Platform.",
  "author": "ECHO Platform",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,mjs,json,css}\"",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "electron-updater": "^6.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^42.0.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.14.0",
    "eslint-plugin-react": "^7.37.2",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.14.0",
    "vite": "^5.4.8",
    "vitest": "^4.1.8"
  }
}
